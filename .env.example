# ──────────────────────────────────────────────────────────────
# MPP+ environment configuration. Copy to .env.local and fill in.
# Never commit real secrets. .env.local is gitignored.
# ──────────────────────────────────────────────────────────────

# Supabase (https://supabase.com → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-side only (jobs)

# ── Category data sources (free tiers) ──
# Football / soccer — https://www.football-data.org/
FOOTBALL_DATA_API_KEY=

# Esports — https://developers.pandascore.co/
PANDASCORE_API_KEY=

# Other sports — https://www.thesportsdb.com/ (free key "3" works for testing)
THESPORTSDB_API_KEY=3

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
