APISPORTS_KEY=your_api_sports_key_here
APISPORTS_BASKETBALL_BASE=https://v1.basketball.api-sports.io
OPENF1_BASE=https://api.openf1.org/v1
JOLPICA_BASE=https://api.jolpi.ca/ergast/f1
PORT=4000
CORS_ORIGINS=*

# Supabase — enables the settlement → push-notification cron (calls the
# send-push Edge Function). Anon/publishable key only; never the service_role key.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# How often to scan for newly-settled predictions and send pushes (ms).
NOTIFY_INTERVAL_MS=300000
